# ── LLM Provider ──────────────────────────────────────────────────────────────
# Switch between "gemini" and "groq" by changing LLM_PROVIDER
LLM_PROVIDER=gemini

# Gemini (default) — get from aistudio.google.com → Get API Key (free tier available)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Groq + Llama 3 — get from console.groq.com (generous free tier)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_SECRET_TOKEN=some-random-secret-string-you-choose

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
